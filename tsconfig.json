{
  "compilerOptions": {
    // Playwright が TS を直接トランスパイル実行するため tsc の出力は不要。この tsconfig は型検査（tsc --noEmit）とエディタ補完・eslint の typed-lint 専用
    "noEmit": true,

    // Playwright は自前で TS を変換して実行するバンドラ型の環境。preserve は「変換は実行側がやる」前提で import を素通しし、相対 import に拡張子を強制しない。NodeNext だと .ts が CommonJS 判定され verbatimModuleSyntax と衝突するため不可
    "target": "ESNext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    // process 等の Node グローバル型。@types/node ^24 と対応
    "types": ["node"],

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    // 依存の .d.ts までは検査しない（型検査を自コードに集中させ高速化）
    "skipLibCheck": true,
    // 型のみの import を import type に強制。eslint の consistent-type-imports と対で「値/型」の境界を明示させる
    "verbatimModuleSyntax": true,

    // 検査の厳しさの土台。暗黙 any 禁止・null 追跡はこの帰結
    "strict": true

    // TODO(human): strict に含まれない追加の厳格化フラグをここに書く
  },
  // typed-lint の対象になる全 TS ファイルを含める。含め漏れると eslint が「project に無い」で落ちる
  "include": [
    "eslint.config.mts",
    "playwright.config.ts",
    "pages/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "test-results",
    "playwright-report",
    "blob-report"
  ]
}
