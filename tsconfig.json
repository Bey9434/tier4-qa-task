{
  "compilerOptions": {
    // テスト実行は Playwright が TS を直接読むため、変換後のファイル出力は不要
    "noEmit": true,

    "target": "ESNext",
    // "NodeNext" だと tsc がこの .ts を CommonJS 扱いし import 文でエラーになるため、
    // TS を自前変換して動かす Playwright に合わせ "preserve" にする
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    // 指定しないと @types 配下の型が全部グローバルに混ざるため Node.js のものだけに絞る
    "types": ["node"],

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    // 依存パッケージ間の型不整合という自分では直せない理由で失敗しないよう検査から外す
    "skipLibCheck": true,
    // 自動判別だと型のみの import が出力から消え、副作用目的の import が黙って落ちうる。
    // eslint の consistent-type-imports と対で運用する
    "verbatimModuleSyntax": true,

    "strict": true
  },
  // 型チェックと eslint の対象にするファイル一覧。ここに載っていないファイルを
  // eslint に読ませると「ファイルが tsconfig に含まれていない」というエラーで落ちる
  "include": [
    "eslint.config.mts",
    "playwright.config.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "config/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "test-results",
    "playwright-report",
    "blob-report",
    "test-target"
  ]
}
