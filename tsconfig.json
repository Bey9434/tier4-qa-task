{
  "compilerOptions": {
    // Playwright が TS を直接実行するので tsc の出力は不要。型検査・補完・typed-lint 専用
    "noEmit": true,

    "target": "ESNext",
    // NodeNext だと .ts が CommonJS 判定され import 構文が verbatimModuleSyntax と衝突する。preserve は変換を実行側(Playwright)に委ね、相対 import に拡張子も強制しない
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    // 指定しないと @types 配下が全部グローバルに入る。node だけに絞る
    "types": ["node"],

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    // 依存の .d.ts は検査しない（自コードに集中・高速化）
    "skipLibCheck": true,
    // 型のみ import を import type に強制（eslint consistent-type-imports と対）
    "verbatimModuleSyntax": true,

    "strict": true

    // TODO(human): strict に含まれない追加の厳格化フラグをここに書く
  },
  // typed-lint 対象の全 TS を含める。漏れると eslint が「project に無い」で落ちる
  "include": [
    "eslint.config.mts",
    "playwright.config.ts",
    "pages/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "test-results",
    "playwright-report",
    "blob-report"
  ]
}
