{
  "name": "tier4-qa-task",
  "version": "1.0.0",
  "description": "Practice Software Testing を対象とした E2E テスト自動化（Playwright + TypeScript）",
  "private": true,
  "scripts": {
    "test": "dotenvx run -- playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.28.2",
  "lint-staged": {
    "*.{ts,mts,cts}": "eslint --fix",
    "**/*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^2.1.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-functional": "^10.0.0",
    "eslint-plugin-playwright": "^2.10.4",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  }
}
